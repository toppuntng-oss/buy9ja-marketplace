# ========================================
# Buy9ja Marketplace API - Environment Configuration
# ========================================

# Server Configuration
# --------------------
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Oracle Autonomous Database Configuration
# ----------------------------------------
# Database credentials from Oracle Cloud Console
DB_USER=ADMIN
DB_PASSWORD=your_admin_password_here
DB_CONNECTION_STRING=your_database_name_high

# Oracle Wallet Configuration
# Path to the extracted wallet directory (absolute path)
WALLET_LOCATION=/path/to/your/wallet/directory
WALLET_PASSWORD=

# Paystack Payment Gateway Configuration
# --------------------------------------
# Get your keys from https://dashboard.paystack.com/#/settings/developer

# Test Keys (for development)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Live Keys (for production - uncomment and use these in production)
# PAYSTACK_SECRET_KEY=sk_live_your_live_secret_key_here
# PAYSTACK_PUBLIC_KEY=pk_live_your_live_public_key_here

# ========================================
# SETUP INSTRUCTIONS
# ========================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update all placeholder values with your actual credentials
# 3. Download Oracle wallet from Oracle Cloud Console
# 4. Extract wallet and update WALLET_LOCATION path
# 5. Get Paystack keys from dashboard.paystack.com
# 6. Run: npm run check (to test database connection)
# 7. Run: npm run dev (to start development server)

